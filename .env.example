# Telegram Bot
BOT_TOKEN=your_bot_token_here

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/teleport_db

# YooKassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot

# Timezone
TIMEZONE=Europe/Moscow

# Admins (JSON array of Telegram user IDs)
ADMIN_IDS=[123456789]
# Admin username without @
ADMIN_USERNAME=your_admin_username

# Closed Telegram chat/channel ID to issue invite links for
ACCESS_CHAT_ID=-1001234567890

# Webhook (leave WEBHOOK_HOST empty to use polling mode for local dev)
WEBHOOK_HOST=https://your-domain.example.com
BOT_WEBHOOK_PATH=/webhook/bot
YOOKASSA_WEBHOOK_PATH=/webhook/yookassa
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
