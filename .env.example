# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Closed Telegram chat/channel ID to issue invite links for
ACCESS_CHAT_ID=-1001234567890

# Admin username without @
ADMIN_USERNAME=your_admin_username

# Admins (JSON array of Telegram user IDs)
ADMIN_IDS=[123456789]

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/teleport_db

# YooKassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_API_KEY=your_secret_key

# Public base URL for webhook (leave empty to use polling in dev mode)
PUBLIC_BASE_URL=https://your-domain.example.com

# Web server
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Receipt settings
TAX_SYSTEM_CODE=1
VAT_CODE=1

# Timezone
TIMEZONE=Europe/Moscow

# Minutes a pending payment is considered reusable
PENDING_REUSE_MINUTES=30

# Recurring payments
RECURRING_ENABLED=false

# Autopay
AUTOPAY_ENABLED=false
AUTOPAY_CHARGE_HOUR=9
AUTOPAY_CHARGE_MINUTE=0
AUTOPAY_PRENOTICE_DAYS=3
AUTOPAY_RETRY_MINUTES=60
AUTOPAY_MAX_RETRIES=3

# Subscription expiry pre-notice
SUBSCRIPTION_PRENOTICE_DAYS=3
PRENOTICE_CHECK_INTERVAL_SECONDS=3600

# Legal URLs
POLICY_URL=https://your-domain.example.com/policy
OFFER_URL=https://your-domain.example.com/offer
